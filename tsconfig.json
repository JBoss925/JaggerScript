{
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "node16",
    "target": "es2020",
    "lib": ["es2020"],
    "noImplicitAny": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "types": ["node"]
  },
  "include": [
    "./compiler/**/*",
    "./interpreter/**/*",
    "./parser/**/*",
    "./*.ts"
  ]
}
